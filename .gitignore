# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vscode
# storybook
storybook-static

# AI workflow local state — prs-context, handoffs, worktree summaries, MCP preflight cache.
# Per-machine, never committed. (Superset of the old prs-context/ entry.)
.vinta-ai-workflows/
pr-screenshots/

# Builder skills installed by `npx vinta-ai-workflows install --tool claude-code`.
# They are symlinks into node_modules carrying a version-pinned pnpm-store path
# (…/vinta-ai-workflows@X.Y.Z/…), so committing them would break for anyone on a
# different resolved version. Re-run the CLI to restore them — required after every
# package bump anyway, since the pinned path stops resolving.
# No trailing slash: git sees these as symlinks (files), not directories.
ai-tools/skills/vinta-*

# Playwright
test-results/
playwright-report/
.playwright/

# build output of workspace packages
packages/*/dist
