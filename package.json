{
  "name": "vinta-schedule-frontend-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup:ai-tools": "node ai-tools/scripts/setup-ai-tools.mjs --only claude",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .gitignore --ignore-path .prettierignore .",
    "typecheck": "tsc --noEmit && pnpm --filter vinta-schedule-design-system typecheck",
    "test": "vitest run && pnpm --filter vinta-schedule-design-system test",
    "test:watch": "vitest",
    "openapi-ts": "openapi-ts",
    "openapi-ts-auth": "openapi-ts -i ./schema-auth.yml -o ./src/auth-client",
    "docs:refresh-schema-snapshot": "node scripts/refresh-graphql-schema-snapshot.mjs",
    "docs:refresh-concepts-snapshot": "node scripts/refresh-concepts-snapshot.mjs",
    "docs:refresh-webhook-events-snapshot": "node scripts/refresh-webhook-events-snapshot.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:ds": "pnpm --filter vinta-schedule-design-system storybook",
    "build-storybook:ds": "pnpm --filter vinta-schedule-design-system build-storybook"
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@graphiql/toolkit": "^0.12.1",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "graphiql": "^5.2.4",
    "graphql": "^17.0.2",
    "lucide-react": "^1.17.0",
    "luxon": "^3.7.2",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-big-calendar": "^1.20.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "unified": "^11.0.5",
    "vinta-schedule-design-system": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-themes": "^10.4.2",
    "@storybook/nextjs-vite": "^10.4.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24",
    "@types/react": "^19.2.16",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.5",
    "jsdom": "^29.1.1",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "raw-loader": "^4.0.2",
    "storybook": "^10.4.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vinta-ai-workflows": "^0.2.0",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "@fortawesome/fontawesome-svg-core": "7.2.0",
      "@fortawesome/fontawesome-common-types": "7.2.0"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
